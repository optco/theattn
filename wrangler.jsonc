{
  "name": "theattn",
  "compatibility_date": "2026-05-09",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.js",
  "assets": {
    "directory": "./dist",       // or whatever your current assets directory is
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/*"]   // run worker first on all paths so it can intercept profile URLs
  }
}
